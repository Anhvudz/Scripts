MineSection:NewToggle({
    Name = "Highlight Resources",
    CurrentValue = false,
    Flag = "ResourceHighlight",
    Callback = function(Value)
        _G.ResourceHighlight = Value
        
        if Value then
            MyHub:Notify("Highlight", "Highlighting resources...", 2)
            
            -- Highlight existing resources
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") then
                    local name = obj.Name:lower()
                    
                    if name:find("gold") or name:find("diamond") or name:find("crystal") then
                        if not obj:FindFirstChild("ResourceHighlight") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "ResourceHighlight"
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            
                            -- Color based on type
                            if name:find("gold") then
                                highlight.FillColor = Color3.fromRGB(255, 215, 0)
                            elseif name:find("diamond") then
                                highlight.FillColor = Color3.fromRGB(0, 191, 255)
                            elseif name:find("crystal") then
                                highlight.FillColor = Color3.fromRGB(255, 0, 255)
                            end
                            
                            highlight.Parent = obj
                        end
                    end
                end
            end
            
            -- Monitor for new resources
            Workspace.DescendantAdded:Connect(function(obj)
                if _G.ResourceHighlight and obj:IsA("Model") then
                    local name = obj.Name:lower()
                    
                    if name:find("gold") or name:find("diamond") or name:find("crystal") then
                        wait(0.1)
                        
                        if not obj:FindFirstChild("ResourceHighlight") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "ResourceHighlight"
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            
                            if name:find("gold") then
                                highlight.FillColor = Color3.fromRGB(255, 215, 0)
                            elseif name:find("diamond") then
                                highlight.FillColor = Color3.fromRGB(0, 191, 255)
                            elseif name:find("crystal") then
                                highlight.FillColor = Color3.fromRGB(255, 0, 255)
                            end
                            
                            highlight.Parent = obj
                        end
                    end
                end
            end)
        else
            -- Remove all highlights
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj.Name == "ResourceHighlight" then
                    obj:Destroy()
                end
            end
            
            MyHub:Notify("Highlight", "Removed!", 2)
        end
    end,
